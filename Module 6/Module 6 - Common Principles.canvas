		{"id":"edge_009","fromNode":"d4e5f6a7b8c9d0e1","fromSide":"left","toNode":"d0e1f2a3b4c5d6e7","toSide":"right","label":"semi-formal"},
		{"id":"edge_010","fromNode":"d0e1f2a3b4c5d6e7","fromSide":"left","toNode":"e1f2a3b4c5d6e7f8","toSide":"right","label":"link"},
		{"id":"edge_011","fromNode":"d4e5f6a7b8c9d0e1","fromSide":"left","toNode":"f2a3b4c5d6e7f8a9","toSide":"right","label":"formal"},
		{"id":"edge_012","fromNode":"f2a3b4c5d6e7f8a9","fromSide":"left","toNode":"a3b4c5d6e7f8a9b0","toSide":"right","label":"link"},
