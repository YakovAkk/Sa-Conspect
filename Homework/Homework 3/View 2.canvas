		{"id":"r6","fromNode":"validation_engine","fromSide":"bottom","toNode":"rule_config_loader","toSide":"top","label":"Reads active rules"},
		{"id":"r7","fromNode":"rule_config_loader","fromSide":"bottom","toNode":"config_store","toSide":"top","label":"Loads rules\n[HTTPS / Config API]"},
